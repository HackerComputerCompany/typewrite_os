# Typewrite OS - Linux Kernel Config for 32-bit (for MacBook Air 2010)

CONFIG_SYSVIPC=y
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_SMP=y
CONFIG_PCI=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# EFI Support for 32-bit
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_EFI_MIXED=y

# i686 (32-bit) architecture
CONFIG_M686=y
CONFIG_X86_GENERIC=y

# Storage - SATA/AHCI
CONFIG_BLK_DEV_SD=y
CONFIG_ATA=y
CONFIG_ATA_PIIX=y
CONFIG_SATA_AHCI=y
CONFIG_ATA_GENERIC=y
CONFIG_PATA_AMD=y
CONFIG_PATA_VIA=y
CONFIG_NVME_CORE=y
CONFIG_BLK_DEV_NVME=y

# Graphics - Intel (32-bit compatible)
CONFIG_DRM=y
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_FBDEV_EMULATION=y
CONFIG_DRM_I915=y
CONFIG_FB_VESA=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_FIRMWARE_EDID=y
CONFIG_FIRMWARE_EDID_FALLBACK=y

# Framebuffer / Console
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_FB=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE_DETECT_PRIMARY=y
CONFIG_FONTS=y
CONFIG_FONT_8x8=y
CONFIG_FONT_8x16=y

# Input
CONFIG_INPUT_EVDEV=y

# Serial
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y

# USB
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_OHCI_HCD=y
CONFIG_USB_STORAGE=y
CONFIG_USB_HID=y

# Filesystems
CONFIG_EXT4_FS=y
CONFIG_TMPFS=y
CONFIG_FAT_FS=y
CONFIG_VFAT_FS=y

# ACPI
CONFIG_ACPI=y
