# Typewrite OS - Linux Kernel Config for Intel Jasper Lake / UHD Graphics
# Supports: VAAPI, OpenGL via Mesa iris, Hardware decode

CONFIG_SYSVIPC=y
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_SMP=y
CONFIG_PCI=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# Storage - SATA/NVMe for modern laptops
CONFIG_VIRTIO_BLK=y
CONFIG_BLK_DEV_SD=y
CONFIG_SCSI_VIRTIO=y
CONFIG_ATA=y
CONFIG_ATA_PIIX=y
CONFIG_SATA_AHCI=y
CONFIG_SATA_AHCI_PLATFORM=y
CONFIG_ATA_GENERIC=y
CONFIG_PATA_AMD=y
CONFIG_PATA_VIA=y
CONFIG_SATA_MV=y
CONFIG_SATA_SIL=y
CONFIG_SATA_SIL24=y
CONFIG_AHCI=y
CONFIG_NVME_CORE=y
CONFIG_BLK_DEV_NVME=y

# Network - disabled for slim build
# CONFIG_NET is not set
# CONFIG_NETDEVICES is not set
# CONFIG_ETHERNET is not set
# CONFIG_NET_CORE is not set

# VirtIO (minimal)
CONFIG_VIRTIO_PCI=y

# Input
CONFIG_INPUT_EVDEV=y

# Serial
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_VIRTIO_CONSOLE=y

# Random
CONFIG_HW_RANDOM_VIRTIO=m
CONFIG_HW_RANDOM_INTEL=m

# Graphics - Intel Jasper Lake / UHD Graphics
CONFIG_DRM=y
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_FBDEV_EMULATION=y
CONFIG_DRM_FBDEV_OVERALLOC=100

# Intel i915 driver (supports Jasper Lake / Elkhart Lake / Comet Lake)
CONFIG_DRM_I915=y
CONFIG_DRM_I915_GVT=y
CONFIG_DRM_I915_GVT_KVMGT=y
CONFIG_DRM_I915_CAPTURE_ERROR=y
CONFIG_DRM_I915_COMPRESS_ERROR=y
CONFIG_DRM_I915_USERPTR=y
CONFIG_DRM_I915_REQUEST_TIMEOUT=20000
CONFIG_DRM_I915_FENCE_TIMEOUT=10000
CONFIG_DRM_I915_USERFAULT_AUTOSUSPEND=250
CONFIG_DRM_I915_HEARTBEAT_INTERVAL=2500
CONFIG_DRM_I915_PREEMPT_TIMEOUT=640
CONFIG_DRM_I915_MAX_REQUEST_BUSYWAIT=8000
CONFIG_DRM_I915_STOP_TIMEOUT=100
CONFIG_DRM_I915_TIMESLICE_DURATION=1

# Intel GEN (Graphics Execution Manager) for VAAPI
CONFIG_I915=y
CONFIG_INTEL_GTT=y
CONFIG_INTEL_IOMMU=y
CONFIG_INTEL_IDLE=y

# VBT (Video BIOS Table) parsing for proper initialization
CONFIG_VIDEO_VGACON_SOFT_SCROLLBACK=y
CONFIG_VIDEO_VGACON_SOFT_SCROLLBACK_SIZE=64

# Framebuffer / Console
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_SCREEN_INFO=y
CONFIG_FB=y
CONFIG_FB_VESA=y
CONFIG_FB_EFI=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE_DETECT_PRIMARY=y
CONFIG_FIRMWARE_EDID=y
CONFIG_FIRMWARE_EDID_FALLBACK=y
CONFIG_FONTS=y
CONFIG_FONT_8x8=y
CONFIG_FONT_8x16=y
CONFIG_FONT_16x32=y

# DRI / Mesa for OpenGL
CONFIG_DRM_LOAD_EDID_FIRMWARE=y
CONFIG_DRM_I915_SPINLOCK=y
CONFIG_DRM_I915_USERPTR=y

# Virtual GPU (for testing in VM)
CONFIG_DRM_BOCHS=y
CONFIG_DRM_VIRTIO_GPU=y

# Sound - Intel HDA
CONFIG_SOUND=y
CONFIG_SND=y
CONFIG_SND_HDA_INTEL=y
CONFIG_SND_HDA_GENERIC=y
CONFIG_SND_HDA_CODEC_HDMI=y
CONFIG_SND_HDA_I915=y

# USB
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_XHCI_PCI=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_EHCI_HCD_PLATFORM=y
CONFIG_USB_UHCI_HCD=y
CONFIG_USB_OHCI_HCD=y
CONFIG_USB_OHCI_LITTLE_ENDIAN=y
CONFIG_USB_STORAGE=y
CONFIG_USB_STORAGE_REALTEK=y
CONFIG_USB_STORAGE_USBAT=y
CONFIG_USB_ACM=y

# USB HID
CONFIG_USB_HID=y
CONFIG_USB_HIDDEV=y
CONFIG_HID_GENERIC=y
CONFIG_HID_APPLE=y
CONFIG_HID_CHERRY=y
CONFIG_HID_LOGITECH=y

# VirtIO
CONFIG_VIRTIO_PCI=y

# Filesystems
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_AUTOFS4_FS=y
CONFIG_TMPFS=y
CONFIG_FAT_FS=y
CONFIG_VFAT_FS=y
CONFIG_FUSE_FS=y

# Slim debug options
CONFIG_UNWINDER_FRAME_POINTER=y

# ACPI (needed for some hardware detection)
CONFIG_ACPI=y
CONFIG_ACPI_AC=y
CONFIG_ACPI_BATTERY=y

# NVM Express (modern storage)
CONFIG_BLK_DEV_NVME=y
CONFIG_NVME_CORE=y
