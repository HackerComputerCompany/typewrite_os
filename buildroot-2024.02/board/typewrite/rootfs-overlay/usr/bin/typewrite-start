#!/bin/sh
# Typewrite OS startup script
# Supports kernel parameters for troubleshooting:
#   shell=1     - Drop to shell instead of starting typewrite
#   nofb=1      - Skip framebuffer, use text console
#   gfxdebug=1  - Run graphics detection and pause

# Parse kernel parameters
SHELL_MODE=0
NOFB_MODE=0
GFXDEBUG_MODE=0

for param in $(cat /proc/cmdline); do
    case "$param" in
        shell=1)
            SHELL_MODE=1
            ;;
        nofb=1)
            NOFB_MODE=1
            ;;
        gfxdebug=1)
            GFXDEBUG_MODE=1
            ;;
    esac
done

# Shell mode - troubleshooting shell
if [ "$SHELL_MODE" = "1" ]; then
    echo ""
    echo "=========================================="
    echo "Typewrite OS - Troubleshooting Mode"
    echo "=========================================="
    echo ""
    echo "Useful commands:"
    echo "  typewrite         - Start the typewriter app"
    echo "  graphics-detect   - Detect graphics hardware"
    echo "  cat /tmp/graphics-detect.log  - View last detection"
    echo "  reboot            - Reboot"
    echo "  poweroff          - Power off"
    echo ""
    exec /bin/sh
fi

# No framebuffer mode - text console
if [ "$NOFB_MODE" = "1" ]; then
    echo "Framebuffer disabled - text mode only"
    exec /sbin/getty -L tty0 115200 vt100
fi

# Graphics debug mode
if [ "$GFXDEBUG_MODE" = "1" ]; then
    echo ""
    echo "=========================================="
    echo "Typewrite OS - Graphics Debug Mode"
    echo "=========================================="
    echo ""
    echo "Running graphics detection..."
    echo ""
    
    if [ -x /usr/bin/graphics-detect ]; then
        /usr/bin/graphics-detect
        echo ""
        echo "Press Enter to continue to typewriter, or Ctrl+C for shell..."
        read answer
    else
        echo "graphics-detect not found!"
        echo "Press Enter to continue..."
        read answer
    fi
fi

# Normal boot

# Run boot logo if available
if [ -x /usr/bin/bootlogo ]; then
    /usr/bin/bootlogo 2>/dev/null
fi

# Clear any leftover framebuffer content
echo "" > /dev/tty1 2>/dev/null

# Quick graphics check - warn if no fb0
if [ ! -e /dev/fb0 ]; then
    echo ""
    echo "WARNING: /dev/fb0 not found!"
    echo "Graphics may not work correctly."
    echo "Try rebooting with 'vga=791' or 'nomodeset' parameter."
    echo ""
    echo "Press Enter to continue anyway, or Ctrl+C for shell..."
    read answer
fi

# Start typewrite
exec /usr/bin/typewrite
