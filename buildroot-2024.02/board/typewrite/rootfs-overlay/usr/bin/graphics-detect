#!/bin/sh
# Graphics Hardware Detection Script for Typewrite OS
# Run at boot to detect and report graphics configuration
# Outputs to /tmp/graphics-detect.log and optionally to console

LOG_FILE="/tmp/graphics-detect.log"
VERBOSE="${VERBOSE:-1}"

log() {
    echo "$1" | tee -a "$LOG_FILE" 2>/dev/null
}

log_verbose() {
    if [ "$VERBOSE" = "1" ]; then
        log "$1"
    fi
}

header() {
    log ""
    log "========================================"
    log "  $1"
    log "========================================"
}

detect_pci_graphics() {
    header "PCI Graphics Devices"
    
    # Check for Intel
    if lspci 2>/dev/null | grep -qi "vga.*intel"; then
        log "Intel GPU detected:"
        lspci 2>/dev/null | grep -i "vga.*intel" | while read line; do
            log "  $line"
        done
        
        # Get Intel generation info if available
        if [ -f /sys/class/drm/card0/device/vendor ]; then
            vendor=$(cat /sys/class/drm/card0/device/vendor 2>/dev/null)
            device=$(cat /sys/class/drm/card0/device/device 2>/dev/null)
            log "  Device ID: $vendor:$device"
        fi
    fi
    
    # Check for NVIDIA
    if lspci 2>/dev/null | grep -qi "vga.*nvidia"; then
        log "NVIDIA GPU detected:"
        lspci 2>/dev/null | grep -i "vga.*nvidia" | while read line; do
            log "  $line"
        done
    fi
    
    # Check for AMD/ATI
    if lspci 2>/dev/null | grep -qi "vga.*amd"; then
        log "AMD GPU detected:"
        lspci 2>/dev/null | grep -i "vga.*amd" | while read line; do
            log "  $line"
        done
    fi
    
    # Check for generic VGA
    if lspci 2>/dev/null | grep -qi "vga.*compat"; then
        log "Standard VGA (Cirrus/VMWare/Bochs):"
        lspci 2>/dev/null | grep -i "vga.*compat" | while read line; do
            log "  $line"
        done
    fi
    
    if ! lspci 2>/dev/null | grep -qi "vga"; then
        log "  No PCI VGA devices found"
    fi
}

detect_drm_devices() {
    header " DRM/KMS Devices"
    
    if [ -d /sys/class/drm ]; then
        log "DRM devices found:"
        for card in /sys/class/drm/card*; do
            if [ -d "$card" ]; then
                name=$(basename "$card")
                status=$(cat "$card/status" 2>/dev/null || echo "unknown")
                log "  $name: status=$status"
                
                # Get driver if available
                if [ -L "$card/driver" ]; then
                    driver=$(readlink "$card/driver" 2>/dev/null | xargs basename)
                    log "    driver=$driver"
                fi
                
                # Get device info
                if [ -f "$card/device/vendor" ]; then
                    vendor=$(cat "$card/device/vendor" 2>/dev/null)
                    device=$(cat "$card/device/device" 2>/dev/null)
                    log "    device=$vendor:$device"
                fi
            fi
        done
    else
        log "  No DRM devices found"
    fi
}

detect_framebuffer() {
    header "Framebuffer Devices"
    
    # Check fb0
    if [ -e /dev/fb0 ]; then
        log "fb0: EXISTS"
        
        # Get fb info from sysfs
        if [ -d /sys/class/graphics/fb0 ]; then
            name=$(cat /sys/class/graphics/fb0/name 2>/dev/null || echo "unknown")
            mode=$(cat /sys/class/graphics/fb0/mode 2>/dev/null || echo "unknown")
            virtual_size=$(cat /sys/class/graphics/fb0/virtual_size 2>/dev/null || echo "unknown")
            acresolution=$(cat /sys/class/graphics/fb0/acre解决方案 2>/dev/null || echo "unknown")
            
            log "  name=$name"
            log "  mode=$mode"
            log "  virtual_size=$virtual_size"
        fi
        
        # Try fbset if available
        if command -v fbset >/dev/null 2>&1; then
            fbset -i /dev/fb0 2>/dev/null | grep -E "mode|geometry" | while read line; do
                log "  fbset: $line"
            done
        fi
    else
        log "fb0: NOT FOUND"
    fi
    
    # Check other framebuffers
    for i in 1 2 3; do
        if [ -e "/dev/fb$i" ]; then
            log "fb$i: EXISTS"
        fi
    done
}

detect_vesa_modes() {
    header "VESA Video Modes (from kernel cmdline)"
    
    # Get current vga= setting
    cmdline=$(cat /proc/cmdline 2>/dev/null)
    vga_param=$(echo "$cmdline" | tr ' ' '\n' | grep '^vga=' | head -1)
    
    if [ -n "$vga_param" ]; then
        log "Current vga= parameter: $vga_param"
        
        # Decode common VESA modes
        case "$vga_param" in
            *785|*0x311*) log "  Mode: 640x480 (VGA)" ;;
        esac
        case "$vga_param" in
            *771|*0x303*) log "  Mode: 800x600 (Safe)" ;;
        esac
        case "$vga_param" in
            *791|*0x317*) log "  Mode: 1024x768 (Normal)" ;;
        esac
        case "$vga_param" in
            *817|*0x331*) log "  Mode: 1280x800 (WXGA)" ;;
        esac
        case "$vga_param" in
            *855|*0x357*) log "  Mode: 1440x900 (WXGA+)" ;;
        esac
        case "$vga_param" in
            *880|*0x370*) log "  Mode: 1366x768" ;;
        esac
        case "$vga_param" in
            *0x1b8|*440*) log "  Mode: 1920x1080 (Full HD)" ;;
        esac
        case "$vga_param" in
            *text*) log "  Mode: Text only" ;;
        esac
    else
        log "No vga= parameter set"
    fi
    
    # Check for video= parameter
    video_param=$(echo "$cmdline" | tr ' ' '\n' | grep '^video=' | head -1)
    if [ -n "$video_param" ]; then
        log "Current video= parameter: $video_param"
    fi
    
    # Check for nomodeset
    if echo "$cmdline" | grep -q "nomodeset"; then
        log "nomodeset: ENABLED (KMS disabled)"
    fi
}

detect_kernel_modesetting() {
    header "Kernel Mode Setting (KMS)"
    
    # Check if i915 is loaded
    if lsmod 2>/dev/null | grep -q i915; then
        log "i915 module: LOADED"
    else
        log "i915 module: NOT LOADED"
    fi
    
    # Check for loaded DRM modules
    if lsmod 2>/dev/null | grep -q "drm"; then
        log "DRM modules:"
        lsmod 2>/dev/null | grep drm | while read line; do
            log "  $line"
        done
    fi
    
    # Check boot params for KMS-related settings
    cmdline=$(cat /proc/cmdline 2>/dev/null)
    
    if echo "$cmdline" | grep -q "i915.modeset=0"; then
        log "i915.modeset=0: KMS disabled for i915"
    fi
    
    if echo "$cmdline" | grep -q "modeset=0"; then
        log "modeset=0: Global KMS disabled"
    fi
}

detect_intel_gpu() {
    header "Intel GPU Details"
    
    # Check for Intel GPU sysfs
    if [ -d /sys/class/drm/card0 ]; then
        # Try to identify generation
        if [ -f /sys/class/drm/card0/device/device ]; then
            device=$(cat /sys/class/drm/card0/device/device 2>/dev/null)
            
            # Jasper Lake GPU ID
            case "$device" in
                0x4e55|0x4E55) log "GPU: Jasper Lake (UHD Graphics)" ;;
                0x9a49|0x9A49) log "GPU: Jasper Lake (UHD Graphics)" ;;
            esac
            
            # Other common Intel GPUs
            case "$(echo $device | tr '[:lower:]' '[:upper:]')" in
                0x*9A*) log "GPU: Jasper Lake" ;;
                0x*4E*) log "GPU: Jasper/Ellac (Gen11)" ;;
                0x*8A*) log "GPU: Ice Lake (Gen11)" ;;
                0x*87*) log "GPU: Kaby Lake (Gen9)" ;;
                0x*59*) log "GPU: Skylake (Gen9)" ;;
                0x*31*) log "GPU: Broadwell (Gen8)" ;;
                0x*2A*) log "GPU: Sandy Bridge (Gen6)" ;;
                0x*46*) log "GPU: Ironlake (Gen5)" ;;
            esac
        fi
        
        # Check for active outputs
        log "Active outputs:"
        for connector in /sys/class/drm/card0/card0-*; do
            if [ -d "$connector" ]; then
                name=$(basename "$connector")
                status=$(cat "$connector/status" 2>/dev/null)
                if [ "$status" = "connected" ]; then
                    log "  $name: CONNECTED"
                fi
            fi
        done
        
        # Check EDID
        for connector in /sys/class/drm/card0/card0-*; do
            if [ -d "$connector" ]; then
                if [ -f "$connector/edid" ]; then
                    name=$(basename "$connector")
                    log "  $name: has EDID"
                fi
            fi
        done
    fi
}

detect_firmware() {
    header "Firmware/EDID Info"
    
    # Check if EDID is being used
    if [ -f /sys/class/graphics/fb0/edid ]; then
        log "EDID available from fb0"
    fi
    
    # Check for i915 firmware
    if [ -d /lib/firmware/i915 ]; then
        log "i915 firmware directory exists"
        count=$(ls /lib/firmware/i915/*.bin 2>/dev/null | wc -l)
        log "  Firmware files: $count"
    fi
}

detect_errors() {
    header "Recent Kernel Errors (dmesg)"
    
    # Look for graphics-related errors in dmesg
    if command -v dmesg >/dev/null 2>&1; then
        errors=0
        
        dmesg 2>/dev/null | grep -iE "(error|failed|panic)" | grep -iE "(gpu|drm|i915|fb|vesa|framebuffer|video)" | while read line; do
            log "  $line"
            errors=$((errors + 1))
        done
        
        if [ $errors -eq 0 ]; then
            log "  No graphics-related errors found"
        fi
    else
        log "  dmesg not available"
    fi
}

recommend_fixes() {
    header "Recommendations"
    
    issues=0
    
    # Check if fb0 exists
    if [ ! -e /dev/fb0 ]; then
        log "ISSUE: No framebuffer device (/dev/fb0)"
        log "  Try: Add 'vga=791' to kernel parameters"
        log "  Try: Boot with 'nomodeset' and check VESA"
        issues=$((issues + 1))
    fi
    
    # Check for DRM issues
    if [ ! -d /sys/class/drm ]; then
        log "ISSUE: No DRM devices"
        log "  GPU may not be detected by kernel"
        issues=$((issues + 1))
    fi
    
    # Check for Intel GPU but no fb0
    if lspci 2>/dev/null | grep -qi "vga.*intel" && [ ! -e /dev/fb0 ]; then
        log "ISSUE: Intel GPU detected but no framebuffer"
        log "  Try: Add 'i915.modeset=1' to kernel parameters"
        log "  Try: Check if i915 module is loaded: lsmod | grep i915"
        issues=$((issues + 1))
    fi
    
    # Check for nouveau
    if lsmod 2>/dev/null | grep -q nouveau; then
        log "WARNING: nouveau driver loaded (NVIDIA)"
        log "  For VESA: add 'nomodeset' to blacklist nouveau"
        issues=$((issues + 1))
    fi
    
    if [ $issues -eq 0 ]; then
        log "No issues detected"
    fi
}

main() {
    # Clear log file
    : > "$LOG_FILE" 2>/dev/null
    
    header "Typewrite OS Graphics Detection"
    log "Date: $(date)"
    log "Kernel: $(uname -r)"
    
    detect_pci_graphics
    detect_drm_devices
    detect_framebuffer
    detect_vesa_modes
    detect_kernel_modesetting
    detect_intel_gpu
    detect_firmware
    detect_errors
    recommend_fixes
    
    header "Detection Complete"
    log "Log saved to: $LOG_FILE"
    log ""
    log "Common fixes:"
    log "  1. Try safe mode: vga=771"
    log "  2. Disable KMS: nomodeset"
    log "  3. Text mode: vga=text"
    log "  4. For Intel: i915.modeset=1"
    log ""
}

# Run if executed directly
if [ "$0" = "${0%.sh}" ] || [ "$(basename "$0")" = "$(basename "$0" .sh)" ]; then
    main "$@"
fi
